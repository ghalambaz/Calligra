# GitHub personal access token
# Generate one at: https://github.com/settings/tokens (needs repo scope)
GIT_TOKEN=

# Branch configured for GitHub Pages in your deploy repository
GIT_DEPLOY_BRANCH=gh-pages

# Remote URL of your deploy repository
# No trailing slash, no quotes around the value
# Format: https://github.com/<user>/<repo>.git
GIT_DEPLOY_REMOTE=

# Path to the build/repository directory (relative or absolute)
# This is a separate git repo where build output is pushed
# Recommended to create your output directory, outside this project.
BUILD_DIR=../

# Optional: Your Dev.to API key for cross-posting (if you want to use this feature)"
DEVTO_API_KEY=

# Change to your custom domain later
SITE_URL="https://calligra.dev" 
BLOG_ROOT_DIR=/src/content/blog
# Notion sync for `make sync` / `prebuild`
# Required database properties expected by the sync script:
# - title field: any Notion title property
# - status field: `status` or `Status`
# - description field: `description` or `Description`
# - category field: `category` or `Category`
# - type field: `type` or `Type`
# - time to read field: `time_to_read`, `time to read`, or `Time to Read`
# - level field: `level` or `Level`
# - tags field: `tags` or `Tags`
# - date field: `datetime`, `Datetime`, or `date`
NOTION_TOKEN=
NOTION_DATABASE_ID=
AUTHOR_NAME="Mohammad Ghalambaz"
# The status value in Notion that indicates a post is ready to publish
PUBLISH_DOC_STATUS="Ready" 
