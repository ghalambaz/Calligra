---
import { getCollection } from 'astro:content';
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export const getStaticPaths = async () => {
    const blog = await getCollection('blog');
    return blog.map(item => {
        const cleanSlug = item.id.replace(/\.mdx?$/, '');
        
        return {
            params: { slug: cleanSlug },
            props: { blog: item }
        };
    });
}

type Props = { blog: CollectionEntry<'blog'> }
const { blog } = Astro.props;
const { Content } = await render(blog);

const date = new Date(blog.data.datetime).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric'
});
const category = blog.data.category ?? 'General';
const tags = blog.data.tags ?? [];
---

<Layout title={blog.data.title}>
  <!-- Progress bar -->
  <div class="progress-bar" id="progress" aria-hidden="true"></div>

  <article class="post-article">
    <!-- Header -->
    <header class="post-header">
      <div class="container mx-auto max-w-3xl px-4 md:px-8">
        <div class="post-meta-top">
          <a href={`/blog/category/${category.toLowerCase().replace(/\s+/g,'-')}`} class="badge-cat">
            {category}
          </a>
          {tags.map(t => (
            <a href={`/blog/tag/${t}`} class="badge-tag">#{t}</a>
          ))}
        </div>
        <h1 class="post-title">{blog.data.title}</h1>
        <p class="post-desc">{blog.data.description}</p>
        <div class="post-byline">
          <time datetime={blog.data.datetime}>{date}</time>
        </div>
      </div>
    </header>

    <!-- Cover image -->
    {blog.data.image && (
      <div class="post-cover">
        <div class="container mx-auto max-w-4xl px-4 md:px-8">
          <img src={blog.data.image} alt={blog.data.title} class="cover-img" loading="eager" />
        </div>
      </div>
    )}

    <!-- Content -->
    <div class="container mx-auto max-w-3xl px-4 md:px-8">
      <div id="markdown" class="prose prose-lg overflow-visible relative my-8 max-w-none">
        <Content />
      </div>

      <!-- Tags footer -->
      {tags.length > 0 && (
        <footer class="post-footer">
          <span class="tags-label">Tagged in</span>
          <div class="tags-list">
            {tags.map(t => (
              <a href={`/blog/tag/${t}`} class="badge-tag">#{t}</a>
            ))}
          </div>
          <a href="/blog" class="back-link">← Back to all posts</a>
        </footer>
      )}
    </div>
  </article>

  <script>
    import { toggleMarkdownTheme } from '../../scripts/theme';
    const theme = document.documentElement.dataset.theme;
    toggleMarkdownTheme(theme);

    // Progress bar
    const bar = document.getElementById('progress');
    if (bar) {
      window.addEventListener('scroll', () => {
        const h = document.documentElement.scrollHeight - window.innerHeight;
        bar.style.width = h > 0 ? `${Math.min((window.scrollY / h) * 100, 100)}%` : '0%';
      }, { passive: true });
    }
  </script>
</Layout>

<style>
.progress-bar {
  position: fixed; top: 0; left: 0;
  height: 2px; width: 0%;
  background: var(--color-primary);
  z-index: 1000;
  transition: width 0.1s linear;
}

.post-article { padding-bottom: 4rem; }

.post-header {
  padding: 2.5rem 0 2rem;
  border-bottom: 1px solid var(--color-border);
  margin-bottom: 0;
}

.post-meta-top { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 1rem; }

.post-title {
  font-size: clamp(1.75rem, 4vw, 2.5rem);
  font-weight: 700;
  line-height: 1.2;
  letter-spacing: -0.02em;
  color: var(--color-text);
  margin-bottom: 0.875rem;
}

.post-desc {
  font-size: 1.0625rem;
  color: var(--color-text-offset);
  line-height: 1.65;
  margin-bottom: 1rem;
}

.post-byline { font-size: 13px; color: var(--color-text-offset); }

.post-cover { padding: 1.75rem 0 0; }
.cover-img {
  width: 100%; border-radius: 14px;
  aspect-ratio: 16/6; object-fit: cover;
}

.post-footer {
  border-top: 1px solid var(--color-border);
  padding-top: 1.5rem;
  margin-top: 2rem;
  display: flex;
  flex-direction: column;
  gap: 0.875rem;
}

.tags-label { font-size: 12px; color: var(--color-text-offset); }
.tags-list { display: flex; gap: 6px; flex-wrap: wrap; }

.back-link {
  font-size: 13px; font-weight: 500;
  color: var(--color-text-offset);
  transition: color 0.15s;
}
.back-link:hover { color: var(--color-text); }

/* Badges */
.badge-cat, .badge-tag {
  display: inline-flex; align-items: center;
  font-size: 11px; font-weight: 600;
  padding: 2px 9px; border-radius: 100px;
  text-decoration: none; transition: opacity 0.15s;
  white-space: nowrap;
}
.badge-cat:hover, .badge-tag:hover { opacity: 0.75; }

.badge-cat {
  background: var(--color-primary);
  color: #fff;
}
.badge-tag {
  background: color-mix(in srgb, var(--color-text) 8%, var(--color-background));
  color: var(--color-text-offset);
  border: 1px solid var(--color-border);
}
</style>
