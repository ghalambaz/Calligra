---

<footer class="site-footer">
  <div class="footer-inner container mx-auto max-w-6xl px-4 md:px-8">
    <p class="footer-copy">© 2026 Mohammad Ghalambaz. All Rights Reserved.</p>

    <nav class="footer-nav" aria-label="Footer navigation">
      {menuItems.map(menu => (
        <a href={menu.link} class="footer-link">{menu.name}</a>
      ))}
    </nav>

    <div class="footer-socials" aria-label="Social links">
      {socialLinks.map(social => (
        <a
          href={social.link}
          title={social.name}
          target="_blank"
          rel="noopener noreferrer"
          class="footer-social-btn"
          aria-label={social.name}
        >
          <span set:html={iconSvgs[social.icon]} aria-hidden="true" />
        </a>
      ))}
    </div>
  </div>
</footer>

<style>
.site-footer {
  border-top: 1px solid var(--color-border);
  padding: 1.75rem 0;
  background: var(--color-background-offset);
}

.footer-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  flex-wrap: wrap;
}

.footer-copy {
  font-size: 13px;
  color: var(--color-text-offset);
}

.footer-nav {
  display: flex;
  gap: 1.25rem;
}

.footer-link {
  font-size: 13px;
  color: var(--color-text-offset);
  text-decoration: none;
  transition: color 0.15s;
}
.footer-link:hover { color: var(--color-text); }

.footer-socials {
  display: flex;
  gap: 4px;
  align-items: center;
}

.footer-social-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32px; height: 32px;
  border-radius: 8px;
  color: var(--color-text-offset);
  text-decoration: none;
  transition: background 0.15s, color 0.15s;
}
.footer-social-btn:hover {
  background: var(--color-background);
  color: var(--color-text);
}

@media (max-width: 600px) {
  .footer-inner { justify-content: center; text-align: center; }
}
</style>
