  devto: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M7.42 10.05c-.18-.16-.46-.23-.84-.23H6l.02 2.44.04 2.45.56-.02c.41 0 .63-.07.83-.26.24-.24.26-.36.26-2.2 0-1.91-.02-1.96-.29-2.18zM0 4.94v14.12h24V4.94H0zM8.56 15.3c-.44.58-1.06.77-2.53.77H4.71V8.53h1.4c1.67 0 2.16.18 2.6.9.27.43.29.6.32 2.57.05 2.23-.02 2.73-.47 3.3zm5.09-5.47h-2.47v1.77h1.52v1.28l-.72.04-.75.03v1.77l1.22.03 1.2.04v1.28h-1.6c-1.53 0-1.6-.01-1.87-.3l-.3-.28v-3.16c0-3.02.01-3.18.25-3.48.23-.31.25-.31 1.88-.31h1.64v1.29zm4.68 5.45c-.17.43-.64.79-1 .79-.18 0-.45-.15-.67-.39-.32-.32-.45-.63-.82-2.08l-.9-3.39-.45-1.67h.76c.4 0 .75.02.75.05 0 .06 1.16 4.54 1.26 4.83.04.15.32-.7.73-2.3l.66-2.52.74-.04c.4-.02.73 0 .73.04 0 .14-1.67 6.38-1.8 6.68z"/></svg>`,
  hashnode: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M22.351 8.019l-6.37-6.37a5.63 5.63 0 0 0-7.962 0l-6.37 6.37a5.63 5.63 0 0 0 0 7.962l6.37 6.37a5.63 5.63 0 0 0 7.962 0l6.37-6.37a5.63 5.63 0 0 0 0-7.962zM12 15.953a3.953 3.953 0 1 1 0-7.906 3.953 3.953 0 0 1 0 7.906z"/></svg>`,
  medium: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M13.54 12a6.8 6.8 0 0 1-6.77 6.82A6.8 6.8 0 0 1 0 12a6.8 6.8 0 0 1 6.77-6.82A6.8 6.8 0 0 1 13.54 12zM20.96 12c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/></svg>`
};
---

<section class="hero-section">
  <div class="hero-inner container mx-auto max-w-6xl px-4 md:px-8">

    <!-- LEFT: avatar + stats -->
    <div class="hero-visual">
      <div class="avatar-wrap">
        <Image
          class="avatar-img"
          src={heroImage}
          loading="eager"
          alt={basic.name}
        />
        <div class="avatar-ring" aria-hidden="true"></div>
      </div>

      <div class="quick-stats">
          <span class="bio-name">Mohammad Ghalambaz</span>
      </div>
    </div>

    <!-- RIGHT: bio + socials -->
    <div class="hero-bio">
      <div class="bio-badge">
        <span class="badge-dot" aria-hidden="true"></span>
        Available for collaboration
      </div>

      <p class="bio-role">
          {
              basic.job.split('\n').map((line) => (
                <span>{line}</span><br />
              ))
          }
      </p>
      <p class="bio-summary">
          {
              basic.summary.split('\n').map((line) => (
                <span>{line}</span><br />
              ))
          }
      </p>
      <p class="bio-summary-extra">{basic.summary_extra}</p>

      <!-- Social buttons -->
      <div class="social-grid" role="list" aria-label="Social profiles">
        {socialLinks.map(social => (
          <a
            href={social.link}
            target="_blank"
            rel="noopener noreferrer"
            class="social-btn"
            title={social.name}
            aria-label={`Visit ${social.name} profile`}
            role="listitem"
          >
            <span class="social-icon" set:html={iconSvgs[social.icon]} aria-hidden="true" />
            <span class="social-name">{social.name}</span>
            <svg class="social-arrow" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path d="M7 17 17 7M7 7h10v10"/>
            </svg>
          </a>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
.hero-section {
  padding: 4rem 0 5rem;
  border-bottom: 1px solid var(--color-border);
}

.hero-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}

/* ── Visual / Avatar ── */
.hero-visual {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rem;
}

.avatar-wrap {
  position: relative;
  width: clamp(200px, 30vw, 320px);
}

.avatar-img {
  width: 100%;
  height: auto;
  border-radius: 24px;
  display: block;
  position: relative;
  z-index: 1;
}

.avatar-ring {
  position: absolute;
  inset: -6px;
  border-radius: 28px;
  border: 2px solid var(--color-border);
  z-index: 0;
}

.quick-stats {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  padding: 1rem 1.5rem;
  border: 1px solid var(--color-border);
  border-radius: 14px;
  background: var(--color-background-offset);
  width: 100%;
  justify-content: center;
}

.stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
}

.stat-num {
  font-size: 1.35rem;
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--color-text);
  line-height: 1;
}

.stat-label {
  font-size: 11px;
  color: var(--color-text-offset);
  white-space: nowrap;
}

.stat-divider {
  width: 1px;
  height: 32px;
  background: var(--color-border);
}

/* ── Bio ── */
.hero-bio {
  display: flex;
  flex-direction: column;
  gap: 1.1rem;
}

.bio-badge {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.03em;
  color: #16a34a;
  background: #dcfce7;
  border: 1px solid #bbf7d0;
  padding: 4px 12px;
  border-radius: 100px;
  width: fit-content;
}

[data-theme="dark"] .bio-badge {
  background: rgba(22,163,74,0.12);
  border-color: rgba(22,163,74,0.25);
  color: #4ade80;
}

.badge-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: #16a34a;
  animation: pulse-dot 2s ease-in-out infinite;
}

[data-theme="dark"] .badge-dot { background: #4ade80; }

@keyframes pulse-dot {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(0.85); }
}

.bio-role {
    font-size: clamp(1rem, 3vw, 2rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-text);
}

.bio-name {
  font-size: clamp(1rem, 3vw, 2rem);
  font-weight: 800;
  line-height: 1.1;
  letter-spacing: -0.03em;
  color: var(--color-text);
}

.bio-summary {
  font-size: 1rem;
  line-height: 1.7;
  color: var(--color-text);
}

.bio-summary-extra {
  font-size: 0.9375rem;
  line-height: 1.65;
  color: var(--color-text-offset);
  padding-left: 1rem;
  border-left: 2px solid var(--color-border);
}

/* ── Social buttons grid ── */
.social-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
  margin-top: 0.25rem;
}

.social-btn {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 9px 12px;
  border: 1px solid var(--color-border);
  border-radius: 10px;
  background: var(--color-background-offset);
  color: var(--color-text);
  text-decoration: none;
  font-size: 13px;
  font-weight: 500;
  transition: border-color 0.15s, background 0.15s, transform 0.15s, box-shadow 0.15s;
  position: relative;
  overflow: hidden;
}

.social-btn:hover {
  border-color: var(--color-primary);
  background: color-mix(in srgb, var(--color-primary) 5%, var(--color-background-offset));
  transform: translateY(-1px);
  box-shadow: 0 4px 12px -4px color-mix(in srgb, var(--color-primary) 25%, transparent);
}

.social-icon {
  width: 16px;
  height: 16px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.social-icon svg {
  width: 16px;
  height: 16px;
}

.social-name { flex: 1; }

.social-arrow {
  opacity: 0;
  transition: opacity 0.15s, transform 0.15s;
  flex-shrink: 0;
}
.social-btn:hover .social-arrow {
  opacity: 0.6;
  transform: translate(1px, -1px);
}

/* ── Responsive ── */
@media (max-width: 900px) {
  .hero-inner {
    grid-template-columns: 1fr;
    gap: 2.5rem;
    text-align: center;
  }

  .hero-visual { order: -1; }

  .avatar-wrap { width: 180px; margin: 0 auto; }

  .bio-badge { margin: 0 auto; }

  .bio-summary-extra { border-left: none; padding-left: 0; border-top: 1px solid var(--color-border); padding-top: 0.875rem; }

  .social-grid { grid-template-columns: repeat(3, 1fr); }
}

@media (max-width: 480px) {
  .social-grid { grid-template-columns: repeat(2, 1fr); }
  .social-btn { font-size: 12px; padding: 8px 10px; gap: 6px; }
}
</style>
