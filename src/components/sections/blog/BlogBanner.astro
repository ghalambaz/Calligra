---
interface Props {
  totalPosts: number;
  categories: string[];
  tags: string[];
  activeCategory?: string;
  activeTag?: string;
}

const { totalPosts, categories, tags, activeCategory, activeTag } = Astro.props;
---

<div class="blog-banner">
  <div class="banner-bg" aria-hidden="true"></div>
  <div class="banner-content container max-w-6xl mx-auto px-4 md:px-8">
    
    <!-- Title & Counter -->
    <div class="banner-top">
      <h1 class="banner-title">
        {activeCategory
          ? activeCategory
          : activeTag
          ? <><span class="hash">#</span>{activeTag}</>
          : 'All Posts'}
      </h1>
      <p class="banner-sub">
        <strong>{totalPosts}</strong> {totalPosts === 1 ? 'post' : 'posts'}
        {activeCategory ? ` in ${activeCategory}` : activeTag ? ` tagged ${activeTag}` : ' published'}
      </p>
    </div>

    <!-- Controls stacked elegantly to the left -->
    <div class="banner-controls">
      <!-- Search box -->
      <div class="search-wrap">
        <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          id="blog-search"
          type="search"
          placeholder="Search..."
          class="search-input"
          aria-label="Search blog posts"
          autocomplete="off"
        />
      </div>

      <!-- Left-aligned filter tracks -->
      <div class="filter-row">
        <!-- Categories -->
        <div class="filter-chips" role="list" aria-label="Filter by category">
          <a
            href="/blogs"
            class:list={['chip', { active: !activeCategory && !activeTag }]}
            role="listitem"
          >All</a>
          {categories.map(cat => (
            <a
              href={`/blogs/category/${cat.toLowerCase().replace(/\s+/g, '-')}`}
              class:list={['chip', { active: activeCategory === cat }]}
              role="listitem"
            >{cat}</a>
          ))}
        </div>

        <!-- Tags -->
        <div class="filter-chips" role="list" aria-label="Filter by Tags">
          {
            [...new Set(tags.flat())].sort().map((singleTag) => (
              <a
                href={`/blogs/tag/${singleTag.toLowerCase().replace(/\s+/g, '-')}`}
                class:list={['chip tag-variant', { active: activeTag === singleTag }]}
                role="listitem"
              >
                <span class="hash-opacity">#</span>{singleTag}
              </a>
            ))
          }
        </div>
      </div>
    </div>

  </div>
</div>

<!-- Search results overlay -->
<div id="search-results" class="search-results" aria-live="polite" hidden></div>

<style>
.blog-banner {
  position: relative;
  padding: 1.5rem 0; 
  margin-top: 1rem;
  margin-bottom: 1.5rem;
  overflow: hidden;
  border-radius: 4px; /* Crisp square structure */
  border: 1px solid var(--color-border, #e5ded0);
}

.banner-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    135deg,
    var(--color-background-offset, #f6f3ea) 0%,
    var(--color-background, #fafaf7) 100%
  );
  z-index: 0;
}

/* Subtle accent background glow */
.banner-bg::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -5%;
  width: 300px;
  height: 300px;
  background: radial-gradient(circle, var(--color-primary, #b36239) 0%, transparent 70%);
  opacity: 0.04;
  border-radius: 50%;
}

.banner-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.banner-top { 
  display: flex; 
  flex-direction: column; 
  gap: 0.2rem; 
}

.banner-title {
  font-size: clamp(1.5rem, 3.5vw, 2.25rem);
  font-weight: 800;
  line-height: 1.2;
  letter-spacing: -0.02em;
  color: var(--color-text, #2d2721);
}

.hash { 
  color: var(--color-primary, #b36239); 
}

.banner-sub {
  font-size: 0.85rem;
  color: var(--color-text-offset, #7a7065);
}
.banner-sub strong {
  color: var(--color-text, #2d2721);
}

/* Controls grouping to the left side */
.banner-controls {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 1rem;
}

/* Squared-off Compact Search Box */
.search-wrap {
  position: relative;
  width: 100%;
  max-width: 320px;
}

.search-icon {
  position: absolute;
  left: 12px;
  top: 50%;
  transform: translateY(-50%);
  color: var(--color-text-offset, #968c7f);
  pointer-events: none;
}

.search-input {
  width: 100%;
  padding: 8px 12px 8px 36px;
  font-size: 13px;
  font-weight: 500;
  border: 1.5px solid var(--color-border, #e5ded0);
  border-radius: 4px; /* Crisp square style */
  background: var(--color-background, #ffffff);
  color: var(--color-text, #2d2721);
  outline: none;
  transition: all 0.2s ease;
}

.search-input:focus {
  border-color: var(--color-primary, #b36239);
  box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary, #b36239) 12%, transparent);
}

/* Horizontal filters matching search path */
.filter-row {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  width: 100%;
  align-items: flex-start;
}

.filter-chips {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}

/* Structured Square Chips */
.chip {
  display: inline-flex;
  align-items: center;
  padding: 4px 10px;
  border-radius: 4px; /* Clean box look instead of circles */
  font-size: 12px;
  font-weight: 600;
  border: 1px solid var(--color-border, #e5ded0);
  background: var(--color-background, #ffffff);
  color: var(--color-text-offset, #544b40);
  text-decoration: none;
  transition: all 0.15s ease;
  white-space: nowrap;
}

.chip:hover {
  border-color: var(--color-primary, #b36239);
  color: var(--color-primary, #b36239);
}

.chip.active {
  background: var(--color-primary, #b36239);
  border-color: var(--color-primary, #b36239);
  color: #ffffff;
}

.tag-variant {
  background: color-mix(in srgb, var(--color-text-offset, #7a7065) 6%, var(--color-background, #ffffff));
}

.hash-opacity {
  opacity: 0.5;
  margin-right: 1px;
}

/* Search Dropdown Overlay with matched tight alignment */
.search-results {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 200;
  background: color-mix(in srgb, var(--color-background-offset, #f6f3ea) 85%, transparent);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-top: 4rem;
}

.search-results[hidden] { 
  display: none; 
}
</style>