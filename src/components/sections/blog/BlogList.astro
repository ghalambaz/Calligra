---
import type { Blog } from '../../../types/BlogType';
import BlogItem from './BlogItem.astro';

interface Props {
  blogs: Blog[];
}

const { blogs } = Astro.props;
const [hero, ...rest] = blogs;
---

<section class="blog-list-section">
  <div class="container mx-auto px-4 max-w-4xl">
    {hero && (
      <div class="hero-wrap">
        <BlogItem blog={hero} isHero={true} />
      </div>
    )}

    {rest.length > 0 && (
      <div class="posts-wrap">
        {hero && <h2 class="posts-label">More Posts</h2>}
        <div class="posts-list">
          {rest.map(blog => (
            <BlogItem blog={blog} isHero={false} />
          ))}
        </div>
      </div>
    )}
  </div>
</section>

<style>
.blog-list-section { padding: 2rem 0 3rem; }

.hero-wrap { margin-bottom: 2.5rem; }

.posts-label {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-text-offset);
  margin-bottom: 1rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--color-border);
}

.posts-list {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}
</style>
