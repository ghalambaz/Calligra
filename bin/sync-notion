#!/usr/bin/env node

import dotenv from 'dotenv';
import { Client } from '@notionhq/client';
import { NotionToMarkdown } from 'notion-to-md';
import * as fs from 'fs';
import * as path from 'path';
import { pipeline } from 'stream/promises';

dotenv.config();

const NOTION_TOKEN = process.env.NOTION_TOKEN;
const NOTION_DATABASE_ID = process.env.NOTION_DATABASE_ID;
const PUBLISH_DOC_STATUS = process.env.PUBLISH_DOC_STATUS;

if (!NOTION_TOKEN) {
  console.error('Error: NOTION_TOKEN is missing. Add it to your .env file.');
  process.exit(1);
}

if (!NOTION_DATABASE_ID) {
  console.error('Error: NOTION_DATABASE_ID is missing. Add it to your .env file.');
  process.exit(1);
}

const notion = new Client({ auth: NOTION_TOKEN });
const n2m = new NotionToMarkdown({ notionClient: notion });
const DATABASE_ID = NOTION_DATABASE_ID;

// Define base root paths
const POSTS_DIR = path.join(process.cwd(), 'src/content/blog');
const IMAGES_BASE_DIR = path.join(process.cwd(), 'public/images/blog');

// Ensure base directories exist
if (!fs.existsSync(POSTS_DIR)) fs.mkdirSync(POSTS_DIR, { recursive: true });
if (!fs.existsSync(IMAGES_BASE_DIR)) fs.mkdirSync(IMAGES_BASE_DIR, { recursive: true });

/**
 * Downloads a binary file from a source URL and writes it locally into a scoped folder per blog post.
 * Returns the public web path string matching Astro asset rendering mechanics.
 */
async function downloadAsset(url, postSlug, filename) {
  try {
    // 💡 Setup a dedicated sub-directory path for this specific blog post
    const postImagesDirectory = path.join(IMAGES_BASE_DIR, postSlug);
    if (!fs.existsSync(postImagesDirectory)) {
      fs.mkdirSync(postImagesDirectory, { recursive: true });
    }

    const response = await fetch(url);
    if (!response.ok) throw new Error(`HTTP network error: ${response.statusText}`);

    const contentType = response.headers.get('content-type');
    let ext = '.png';
    if (contentType?.includes('image/jpeg')) ext = '.jpg';
    if (contentType?.includes('image/webp')) ext = '.webp';
    if (contentType?.includes('image/gif')) ext = '.gif';

    const cleanFilename = `${filename}${ext}`;
    const destinationPath = path.join(postImagesDirectory, cleanFilename);

    await pipeline(response.body, fs.createWriteStream(destinationPath));
    
    // 💡 Returns clean public-facing URL path, referencing the newly created subfolder
    return `/images/blog/${postSlug}/${cleanFilename}`;
  } catch (err) {
    console.error(`⚠️ Failed to download file [${url}]:`, err.message);
    return url; // Graceful degradation fallback
  }
}

function getProperty(properties, candidates) {
  for (const key of candidates) {
    if (properties[key]) return properties[key];
  }
  return null;
}

function getTitle(properties) {
  const titleProperty = Object.values(properties).find((property) => property.type === 'title');
  return titleProperty?.title?.[0]?.plain_text ?? 'Untitled';
}

function getSelectName(properties, candidates, fallback) {
  const property = getProperty(properties, candidates);
  return property?.select?.name ?? fallback;
}

function getNumber(properties, candidates, fallback) {
  const property = getProperty(properties, candidates);
  return typeof property?.number === 'number' ? property.number : fallback;
}

function getTags(properties, candidates) {
  const property = getProperty(properties, candidates);
  return property?.multi_select?.map((item) => item.name) ?? [];
}

function getCategory(properties, candidates) {
  const property = getProperty(properties, candidates);
  return property?.multi_select?.[0]?.name ?? 'Uncategorized';
}

async function fetchAllPages(databaseId) {
  const pages = [];
  let cursor = undefined;

  while (true) {
    const response = await notion.dataSources.query({
      data_source_id: databaseId,
      start_cursor: cursor,
      page_size: 100,
    });
    pages.push(...response.results);

    if (!response.has_more || !response.next_cursor) {
      break;
    }

    cursor = response.next_cursor;
  }

  return pages;
}

async function syncPosts() {
  const pages = await fetchAllPages(DATABASE_ID);

  for (const page of pages) {
    const props = page.properties;
    const statusProperty = getProperty(props, ['status', 'Status']);
    const readyToPublish = statusProperty?.status?.name === PUBLISH_DOC_STATUS;
    if (!readyToPublish) continue; 

    const title = getTitle(props);
    const description = getProperty(props, ['description', 'Description'])?.rich_text?.[0]?.plain_text ?? '';
    const category = getCategory(props, ['category', 'Category']);
    const type = getSelectName(props, ['type', 'Type'], 'Article');
    const level = getSelectName(props, ['level', 'Level'], 'Beginner');
    const timeToRead = getNumber(props, ['time_to_read', 'time to read', 'Time to Read'], 5);
    const tags = getTags(props, ['tags', 'Tags']);
    const datetime = getProperty(props, ['datetime', 'Datetime', 'date'])?.date?.start ?? new Date().toISOString();
    const slug = title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');

    console.log(`Processing content: "${title}"...`);

    // 1. Process and Download Page Cover into its dedicated subfolder
    let coverImagePath = '';
    if (page.cover) {
      const originalCoverUrl = page.cover.type === 'file' ? page.cover.file.url : page.cover.external.url;
      // 💡 Pass the slug to group the assets within their own bundle folder
      coverImagePath = await downloadAsset(originalCoverUrl, slug, 'cover');
    }

    // 2. Set up inline image downloader logic inside notion-to-md context 
    let blockImageCounter = 0;
    n2m.setCustomTransformer('image', async (block) => {
      const imageUrl = block.image.type === 'file' ? block.image.file.url : block.image.external.url;
      const caption = block.image.caption?.[0]?.plain_text || '';
      
      blockImageCounter++;
      // 💡 Group inline assets together with the main banner cover
      const localImagePath = await downloadAsset(imageUrl, slug, `asset-${blockImageCounter}`);
      
      return `![${caption || 'Blog Asset'}](${localImagePath})`;
    });

    // 3. Fetch content blocks and convert
    const mdblocks = await n2m.pageToMarkdown(page.id);
    const mdString = n2m.toMarkdownString(mdblocks);

    // 4. Construct Astro Frontmatter with clean local relative cover paths
    const frontmatter = `---
title: "${title}"
description: "${description}"
category: "${category}"
type: "${type}"
time_to_read: ${timeToRead}
level: "${level}"
tags: ${JSON.stringify(tags)}
datetime: "${datetime}"
image: "${coverImagePath}"
---

`;

    const fullContent = frontmatter + mdString.parent;
    const outputPath = path.join(POSTS_DIR, `${slug}.mdx`);
    
    fs.writeFileSync(outputPath, fullContent);
    console.log(`Successfully completed build for: ${slug}.mdx`);
  }
}

syncPosts();