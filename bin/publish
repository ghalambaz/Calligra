#!/usr/bin/env node
/**
 * crosspost.js — Cross-post blog articles to Dev.to, Hashnode, and Medium.
 *
 * USAGE
 * ─────
 * npm run crosspost                       # scan all changed posts
 * npm run crosspost -- --slug <slug>      # process one specific post
 *
 * HASH MANAGEMENT
 * ───────────────
 * npm run crosspost -- --hash-reset <slug>          # force reprocess a post next run
 * npm run crosspost -- --hash-reset-all             # force reprocess all posts next run
 * npm run crosspost -- --hash-show                  # show all stored hashes
 *
 * FRONTMATTER MANAGEMENT
 * ──────────────────────
 * npm run crosspost -- --set <slug> published=true
 * npm run crosspost -- --set <slug> published=false
 * npm run crosspost -- --set <slug> devto_id=null
 *
 * REQUIREMENTS
 * ────────────
 * - DEVTO_API_KEY in .env
 * - Posts in src/content/blog/<slug>.md or .mdx
 * - Exports written to src/content/export/
 * - Hashes stored in src/content/export/.hashes.json
 *
 * DEPENDENCIES (already in Astro projects)
 * ─────────────────────────────────────────
 * npm install gray-matter marked dotenv
 */

import fs from "fs";
import path from "path";
import crypto from "crypto";
import matter from "gray-matter";
import { marked } from "marked";
import dotenv from "dotenv";

dotenv.config();

// ─── Config ──────────────────────────────────────────────────────────────────

const PUBLIC_CONTENT_DIR = path.join(process.cwd(), 'public/blog');
const BLOG_DIR    = path.resolve("src/content/blog");
const EXPORT_DIR  = path.resolve("src/content/");
const HASHES_FILE = path.join(EXPORT_DIR, ".generated.json");
const BASE_URL    = process.env.SITE_URL + "/blog";
const DEVTO_API   = "https://dev.to/api/articles";

// ─── CLI args ─────────────────────────────────────────────────────────────────

const args = process.argv.slice(2);

function getArg(flag) {
  const idx = args.indexOf(flag);
  return idx !== -1 ? args[idx + 1] ?? true : null;
}

const MODE_SLUG        = getArg("--slug");
const MODE_SET         = getArg("--set");
const MODE_HASH_RESET  = getArg("--hash-reset");
const MODE_HASH_ALL    = args.includes("--hash-reset-all");
const MODE_HASH_SHOW   = args.includes("--hash-show");

// ─── Logging ─────────────────────────────────────────────────────────────────

const log  = (emoji, msg) => console.log(`${emoji}  ${msg}`);
const warn = (msg)        => console.warn(`⚠️   ${msg}`);
const sep  = ()           => console.log("━".repeat(52));

function bail(msg) {
  console.error(`❌  ${msg}`);
  process.exit(1);
}

// ─── File helpers ─────────────────────────────────────────────────────────────

function ensureExportDir() {
  if (!fs.existsSync(EXPORT_DIR)) {
    fs.mkdirSync(EXPORT_DIR, { recursive: true });
    log("📁", `Created: ${EXPORT_DIR}`);
  }
}

function findPostFile(slug) {
  for (const ext of [".md", ".mdx"]) {
    const p = path.join(BLOG_DIR, `${slug}${ext}`);
    if (fs.existsSync(p)) return p;
  }
  bail(`No file found for slug "${slug}" in ${BLOG_DIR}`);
}

function getAllSlugs() {
  if (!fs.existsSync(BLOG_DIR)) bail(`Blog directory not found: ${BLOG_DIR}`);
  return fs.readdirSync(BLOG_DIR)
    .filter(f => f.endsWith(".md") || f.endsWith(".mdx"))
    .map(f => f.replace(/\.(md|mdx)$/, ""));
}

// ─── Hash helpers ─────────────────────────────────────────────────────────────

function loadHashes() {
  if (!fs.existsSync(HASHES_FILE)) return {};
  try { return JSON.parse(fs.readFileSync(HASHES_FILE, "utf-8")); }
  catch { return {}; }
}

function saveHashes(hashes) {
  ensureExportDir();
  fs.writeFileSync(HASHES_FILE, JSON.stringify(hashes, null, 2), "utf-8");
}

function hashFile(filePath) {
  const content = fs.readFileSync(filePath, "utf-8");
  return crypto.createHash("sha256").update(content).digest("hex");
}

function hasChanged(slug, filePath, hashes) {
  const current = hashFile(filePath);
  return hashes[slug] !== current;
}

// ─── Frontmatter helpers ──────────────────────────────────────────────────────

function readPost(filePath) {
  const raw = fs.readFileSync(filePath, "utf-8");
  const { data, content } = matter(raw);
  return { raw, frontmatter: data, content };
}

function writeFrontmatterKey(filePath, key, value) {
  const raw = fs.readFileSync(filePath, "utf-8");
  const parsed = matter(raw);
  parsed.data[key] = value;
  const updated = matter.stringify(parsed.content, parsed.data);
  fs.writeFileSync(filePath, updated, "utf-8");
}

/** Remove Astro-specific MDX imports and JSX component tags */
function stripAstroSyntax(content) {
  return content
    // Remove import statements
    .replace(/^import\s+.*from\s+['"].*['"]\s*;?\s*$/gm, "")
    // Remove self-closing JSX components
    .replace(/<[A-Z][A-Za-z0-9]*[^>]*\/>/g, "")
    // Remove opening/closing JSX tags
    .replace(/<\/?[A-Z][A-Za-z0-9]*[^>]*>/g, "")
    // Fix "plain text" code fence language identifier
    .replace(/```plain text/gi, "```plaintext")
    // Remove any leftover blank lines caused by stripped imports (collapse 3+ newlines to 2)
    .replace(/\n{3,}/g, "\n\n")
    .trim();
}

/** Normalize tags to Dev.to format: lowercase, no spaces, max 4 */
function normalizeTags(tags) {
  if (!Array.isArray(tags)) return [];
  return tags
    .map(t =>
      String(t)
        .toLowerCase()
        .replace(/[^a-z0-9]/g, "")
    )
    .filter(t => t.length > 0)
    .slice(0, 4);
}

/**
 * Replaces relative image paths in Markdown with absolute URLs.
 * Handles: ./image.png  /image.png  image.png  (but not http/https already)
 */
function normalizeImagePaths(content, slug) {
  const siteUrl = process.env.SITE_URL.replace(/\/$/, "");
  return content.replace(/!\[(.*?)\]\((?!https?:\/\/)(.*?)\)/g, (match, alt, imgPath) => {
    const cleanPath = imgPath.replace(/^\.?\//, "");
    return `![${alt}](${siteUrl}/${cleanPath})`;
  });
}

/** Build a full absolute cover image URL from frontmatter.image */
function buildCoverUrl(frontmatter) {
  if (!frontmatter.image) return null;
  const siteUrl = process.env.SITE_URL.replace(/\/$/, "");
  if (frontmatter.image.startsWith("http")) return frontmatter.image;
  return `${siteUrl}${frontmatter.image.startsWith("/") ? "" : "/"}${frontmatter.image}`;
}

// ─── Dev.to ───────────────────────────────────────────────────────────────────

async function publishToDevto(filePath, slug, frontmatter, content) {
  const DEVTO_API_KEY = process.env.DEVTO_API_KEY;
  if (!DEVTO_API_KEY) bail("DEVTO_API_KEY is not set in your .env file.");

  const canonicalUrl = `${BASE_URL}/${slug}`;
  const existingId   = frontmatter.devto_id ?? null;
  const isUpdate     = typeof existingId === "number";
  const coverUrl     = buildCoverUrl(frontmatter);

  const payload = {
    article: {
      title:         frontmatter.title,
      body_markdown: content,
      published:     frontmatter.published ?? false,
      description:   frontmatter.description ?? "",
      tags:          normalizeTags(frontmatter.tags),
      canonical_url: canonicalUrl,
      main_image:    coverUrl,
    }
  };

  const url    = isUpdate ? `${DEVTO_API}/${existingId}` : DEVTO_API;
  const method = isUpdate ? "PUT" : "POST";

  log("🚀", `Dev.to: ${isUpdate ? `Updating article #${existingId}` : "Creating new article"}...`);

  const res = await fetch(url, {
    method,
    headers: { "Content-Type": "application/json", "api-key": DEVTO_API_KEY },
    body: JSON.stringify(payload),
  });

  if (!res.ok) {
    const body = await res.text();
    bail(`Dev.to API error ${res.status}: ${body}`);
  }

  const data = await res.json();
  if (!isUpdate) {
    writeFrontmatterKey(filePath, "devto_id", data.id);
    log("✅", `Dev.to: Published! devto_id=${data.id} written to frontmatter.`);
  } else {
    log("✅", `Dev.to: Updated successfully.`);
  }

  log("🔗", `Dev.to URL: ${data.url}`);
  log("🔗", `Open drafts: https://dev.to/dashboard`);
}

// ─── Hashnode export ──────────────────────────────────────────────────────────
//
//  Hashnode's "Import from Markdown" dialog accepts a clean .md file.
//  It does NOT read YAML frontmatter — you fill in title/tags/cover in the UI.
//  So we output:
//    1. A pure markdown body (no frontmatter block) for paste / import
//    2. A small instruction block at the top of the .md file (inside an HTML
//       comment so Hashnode ignores it) telling you what to fill in manually.

function exportForHashnode(slug, frontmatter, content) {
  const canonicalUrl = `${BASE_URL}/${slug}`;
  const coverUrl     = buildCoverUrl(frontmatter);
  const tags         = (frontmatter.tags ?? []).join(", ");

  const instructions = [
    `<!--`,
    `  HASHNODE PUBLISH INSTRUCTIONS`,
    `  ══════════════════════════════════════════════════════`,
    `  1. Go to hashnode.com → Write → "Import article"`,
    `     OR paste content below into the Hashnode editor directly.`,
    ``,
    `  2. After import / paste, fill in the UI fields:`,
    `     • Title       : ${frontmatter.title}`,
    `     • Subtitle    : ${frontmatter.description ?? "(none)"}`,
    `     • Slug        : ${slug}`,
    `     • Tags        : ${tags}`,
    `     • Cover image : ${coverUrl ?? "(no cover — upload manually)"}`,
    ``,
    `  3. Under "SEO" settings:`,
    `     • Canonical URL: ${canonicalUrl}`,
    ``,
    `  4. Save as draft, review, then publish.`,
    `  ══════════════════════════════════════════════════════`,
    `-->`,
    ``,
  ].join("\n");

  const out = instructions + content;

  const outPath = path.join(PUBLIC_CONTENT_DIR, `/${slug}/hashnode.md`);
  const outDir  = path.dirname(outPath);
  if (!fs.existsSync(outDir)) fs.mkdirSync(outDir, { recursive: true });
  fs.writeFileSync(outPath, out, "utf-8");

  const publicPath = BASE_URL + `/content/${slug}/hashnode.md`;
  log("✅", `Hashnode markdown ready: ${publicPath}`);
  if (coverUrl) log("🖼️ ", `Hashnode cover URL: ${coverUrl}`);
}

// ─── Medium export ────────────────────────────────────────────────────────────
//
//  KEY INSIGHT: Medium's paste handler does NOT reliably parse <pre><code>
//  blocks. The bug is not in the markdown→HTML conversion — it's that
//  opening the exported .html in a browser and copying it sends Medium the
//  browser's *rendered rich-text clipboard serialization*, not raw HTML.
//  Browsers are inconsistent serializing multi-line <pre> content to the
//  clipboard: lines get split into separate blocks, stray <br>s appear,
//  and an empty trailing block often shows up right after </pre>. This is
//  a known Medium/clipboard quirk, not something fixable from the markdown
//  source side.
//
//  FIX: never emit <pre><code>. Each code line is rendered as escaped text
//  joined by explicit <br> tags inside a plain <div>. There's no <pre>
//  whitespace-preservation behavior left for the browser to mangle, since
//  every line break is already a real DOM-level element boundary.
//
//  Cover image: Medium has no programmatic cover upload. The cover is
//  placed as the very first <img> in the body — pasting into Medium turns
//  the first image in a paste into the story's cover/thumbnail automatically.

function buildMediumRenderer() {
  const renderer = new marked.Renderer();

  // CONTEXT: you're using Medium's "Import a story" (URL import), not
  // copy-paste. That means Medium runs its OWN html→Medium-blocks parser
  // on this file directly — clipboard serialization is not involved at all.
  // A custom <div class="code-block"><p class="code-line"> structure has
  // no special handling in that parser, so it likely falls through to
  // generic paragraph-import logic and misbehaves (collapsed lines, stray
  // empty blocks). Standard <pre><code> is the one pattern every HTML
  // importer is built and tested against, so we use that instead.
  // DIAGNOSIS (confirmed from Medium's actual imported HTML): Medium's
  // importer ignores our `class="language-X"` hint entirely. The class
  // names it actually outputs (hljs-built_in, hljs-selector-class) are
  // highlight.js's own token classes — Medium runs highlight.js's AUTO
  // DETECTION server-side on import, regardless of what we send. That
  // detector misread the ASCII diagram as SCSS (mistaking ".to" in
  // "Dev.to" for a CSS class selector) and `make` commands as Go, and in
  // the process collapsed real newlines into spaces/run-together text.
  //
  // FIX: highlight.js has a standard convention to suppress auto-detection
  // — class="nohighlight" tells it "plain text, don't guess, don't touch
  // whitespace." We apply that whenever the markdown fence's language is
  // "plaintext" (or unspecified) — i.e. exactly the blocks with no real
  // language, like ASCII diagrams — since those are what the detector
  // gets wrong. Real language fences (bash, js, etc.) are passed through
  // normally so highlight.js can still apply real syntax highlighting,
  // since you confirmed you want that kept for actual code.
renderer.code = function ({ text, lang }) {
  const normalizedLang = (lang || "auto").toLowerCase().trim();
  const lines = text.split('\n').map(line => {
    return `${line}`; // Use graf--pre for line-by-line
  }).join('\n');

  return `<pre>${lines}</pre>`;
};

  // Medium's importer produced 2 extra EMPTY <blockquote> elements and
  // wrapped the quote text in <em> (unwanted italics) when given
  // <blockquote><p>text</p></blockquote>. The inner <p> plus surrounding
  // newlines is the non-standard part — most blockquote markup across the
  // web is <blockquote>text</blockquote> with no nested block element, so
  // we match that shape exactly: no inner <p>, no surrounding whitespace.
  // CONFIRMED FROM ACTUAL MEDIUM IMPORT OUTPUT: the 2 extra empty
  // <blockquote class="graf--empty"><br></blockquote> siblings are NOT
  // caused by anything in our input shape — Medium's importer inserts an
  // empty sibling of the same tag as a spacing convention throughout the
  // ENTIRE document (e.g. an empty <h3><br></h3> follows nearly every
  // real h3 in the imported result, even though our source never asked
  // for that). This is Medium's own post-import normalization, applied
  // uniformly regardless of input — it cannot be suppressed by changing
  // the blockquote markup we send. Tried bare-text and single-line-<p>
  // wrapping; neither changed the duplication. The <em> italics wrapping
  // is also applied by Medium itself (its default blockquote styling on
  // import), not something we're introducing from our side.
  renderer.blockquote = function ({ tokens }) {
    const inner = this.parser.parseInline(
      tokens.flatMap(t => t.tokens || [])
    );
    return `<em>${inner}</em>`;
  };

  return renderer;
}

/** * Post-processes the HTML to fix common Medium import quirks.
 * 1. Removes empty blockquote structures that Medium misinterprets.
 * 2. Ensures code blocks are explicitly styled for plain text to stop Medium's
 * auto-detection from mangling ASCII/code.
 */
function postProcessMediumHtml(html) {
  return html
    // 1. Remove empty/malformed blockquotes that cause stray blank quotes
    .replace(/<blockquote>\s*<p>\s*<\/p>\s*<\/blockquote>/g, '')
    .replace(/<blockquote>\s*<\/blockquote>/g, '')
    
    // 2. Wrap <pre><code> in a container if needed, or ensure the code tag 
    //    has 'class="nohighlight"' to prevent auto-detection (which causes the line collapse)
    .replace(/<pre><code class="language-plaintext">/g, '<pre><code class="pre--content">');
}

async function exportForMedium(slug, frontmatter, content) {
  const canonicalUrl = `${BASE_URL}/${slug}`;
  const coverUrl     = buildCoverUrl(frontmatter);
  const tags         = (frontmatter.tags ?? []).slice(0, 5).join(", ");

  // breaks:true is intentionally OFF for the body text — it inserts a <br>
  // on every soft-wrapped line inside ordinary paragraphs (not just code),
  // which fragments prose if your source .md has soft line wraps. The
  // code-block-specific renderer above is what actually fixes the bug you
  // hit; breaks:true was treating a symptom in the wrong place.
  const bodyHtml = await marked.parse(content, {
    gfm: true,
    breaks: false,
    renderer: buildMediumRenderer(),
  });

  const cleanedHtml = postProcessMediumHtml(bodyHtml);

  const coverBlock = coverUrl
    ? `  <img src="${coverUrl}" alt="${frontmatter.title} cover image" />\n`
    : "";

  const html = `<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>${frontmatter.title}</title>
  <!--
    MEDIUM PUBLISH INSTRUCTIONS
    ══════════════════════════════════════════════════════
    1. Open this file in your browser (File > Open, or drag it in).
    2. Press Ctrl+A (Cmd+A on Mac) to select everything, then Ctrl+C to copy.
    3. Go to medium.com → Write a story → click into the editor → Ctrl+V to paste.
    4. After pasting, set:
       • Title: ${frontmatter.title}
       • Subtitle / description: ${frontmatter.description ?? "(none)"}
       • Tags (up to 5): ${tags}
    5. Before publishing → "..." menu → "Change display title/subtitle"
    6. Set "Originally published at": ${canonicalUrl}
    7. Cover image: ${coverUrl ? `The first image in the paste should appear as cover.
       If not, use this URL directly in Medium's cover uploader:
       ${coverUrl}` : "No cover — upload manually via the Medium cover tool."}
    ══════════════════════════════════════════════════════
  -->
  <style>
    /*
     * These styles only affect local preview in your browser.
     * Medium strips all CSS when you paste — that's expected.
     */
    body        { font-family: Georgia, serif; max-width: 740px; margin: 40px auto; line-height: 1.75; color: #292929; }
    h1          { font-size: 2rem; font-weight: 700; margin-bottom: 0.25em; }
    h2          { font-size: 1.5rem; font-weight: 700; margin-top: 2em; }
    h3          { font-size: 1.2rem; font-weight: 600; margin-top: 1.5em; }
    p           { margin: 1em 0; }
    pre         { background: #f4f4f4; padding: 1em; border-radius: 4px; overflow-x: auto; }
    code        { font-family: monospace; font-size: 0.9em; }
    blockquote  { border-left: 3px solid #ccc; margin: 1em 0; padding-left: 1em; color: #555; }
    img         { max-width: 100%; height: auto; display: block; margin: 1.5em 0; }
    a           { color: #1a8917; }
  </style>
</head>
<body>
${coverBlock}  <h1>${frontmatter.title}</h1>
${cleanedHtml}
</body>
</html>`;

  const outPath = path.join(PUBLIC_CONTENT_DIR, `/${slug}/medium.html`);
  const outDir  = path.dirname(outPath);
  if (!fs.existsSync(outDir)) fs.mkdirSync(outDir, { recursive: true });
  fs.writeFileSync(outPath, html, "utf-8");

  const publicHtmlPath = BASE_URL + `/${slug}/medium.html`;
  if (coverUrl) log("🖼️ ", `Medium cover URL (first <img> in paste): ${coverUrl}`);
  log("🔗", `Medium HTML file: ${publicHtmlPath}`);
  log("✅", `Paste into: https://medium.com/p/import`);
}

// ─── Process one post ─────────────────────────────────────────────────────────

async function processPost(slug, hashes) {
  const filePath = findPostFile(slug);
  const { frontmatter, content: rawContent } = readPost(filePath);

  if (!frontmatter.title) {
    warn(`Skipping "${slug}" — missing required frontmatter field: title`);
    return false;
  }

  if (frontmatter.published === undefined) {
    warn(`"${slug}" has no published field — defaulting to draft`);
  }

  let content = stripAstroSyntax(rawContent);
  content = normalizeImagePaths(content, slug);

  sep();
  log("📄", `Processing: ${slug}`);
  sep();

  await publishToDevto(filePath, slug, frontmatter, content);
  sep();
  exportForHashnode(slug, frontmatter, content);
  sep();
  await exportForMedium(slug, frontmatter, content);

  // Update hash AFTER processing (devto_id writeback changes file hash)
  hashes[slug] = hashFile(filePath);
  return true;
}

// ─── Mode: --set <slug> key=value ─────────────────────────────────────────────

function runSet(slug, assignment) {
  if (!assignment || !assignment.includes("=")) {
    bail(`--set requires key=value format.\n   Example: --set ${slug} published=true`);
  }

  const eqIdx = assignment.indexOf("=");
  const key   = assignment.slice(0, eqIdx).trim();
  const raw   = assignment.slice(eqIdx + 1).trim();

  let value;
  if (raw === "null")        value = null;
  else if (raw === "true")   value = true;
  else if (raw === "false")  value = false;
  else if (!isNaN(Number(raw)) && raw !== "") value = Number(raw);
  else value = raw;

  const filePath = findPostFile(slug);
  writeFrontmatterKey(filePath, key, value);

  log("✅", `Set ${key}=${JSON.stringify(value)} in ${slug}`);
  log("💡", `Hash cleared — this post will be reprocessed on next run.`);

  const hashes = loadHashes();
  delete hashes[slug];
  saveHashes(hashes);
}

// ─── Mode: --hash-show ────────────────────────────────────────────────────────

function runHashShow() {
  const hashes = loadHashes();
  const slugs  = Object.keys(hashes);

  if (slugs.length === 0) {
    log("📭", "No hashes stored yet — all posts will be processed on next run.");
    return;
  }

  console.log("\n  Stored hashes:\n");
  for (const [slug, hash] of Object.entries(hashes)) {
    const filePath = path.join(BLOG_DIR, `${slug}.md`) || path.join(BLOG_DIR, `${slug}.mdx`);
    const exists   = fs.existsSync(filePath) || fs.existsSync(filePath.replace(".md", ".mdx"));
    const current  = exists ? hashFile(filePath) : null;
    const changed  = current && current !== hash;
    const status   = !exists ? "⚠️  file missing" : changed ? "🔄 changed" : "✓  up to date";
    console.log(`  ${status.padEnd(18)} ${slug}`);
    console.log(`  ${"".padEnd(18)} stored:  ${hash.slice(0, 16)}...`);
    if (current) console.log(`  ${"".padEnd(18)} current: ${current.slice(0, 16)}...`);
    console.log("");
  }
}

// ─── Mode: --hash-reset / --hash-reset-all ───────────────────────────────────

function runHashReset(slug) {
  const hashes = loadHashes();
  if (slug === true) bail("--hash-reset requires a slug argument.");
  delete hashes[slug];
  saveHashes(hashes);
  log("🔄", `Hash cleared for "${slug}" — will reprocess on next run.`);
}

function runHashResetAll() {
  saveHashes({});
  log("🔄", "All hashes cleared — all posts will reprocess on next run.");
}

// ─── Main ─────────────────────────────────────────────────────────────────────

async function main() {
  if (MODE_HASH_SHOW)  return runHashShow();
  if (MODE_HASH_ALL)   return runHashResetAll();
  if (MODE_HASH_RESET) return runHashReset(MODE_HASH_RESET);
  if (MODE_SET) {
    const slug       = MODE_SET;
    const assignment = args[args.indexOf("--set") + 2];
    return runSet(slug, assignment);
  }

  ensureExportDir();
  const hashes = loadHashes();

  let slugs;
  if (MODE_SLUG) {
    slugs = [MODE_SLUG];
    log("🎯", `Single post mode: ${MODE_SLUG}`);
  } else {
    slugs = getAllSlugs();
    log("🔍", `Scanning ${slugs.length} post(s) in ${BLOG_DIR}...`);
  }

  const toProcess = slugs.filter(slug => {
    const filePath = findPostFile(slug);
    if (!hasChanged(slug, filePath, hashes)) {
      log("⏭️ ", `No changes: ${slug}`);
      return false;
    }
    return true;
  });

  if (toProcess.length === 0) {
    console.log("");
    log("✨", "All posts are up to date. Nothing to publish.");
    return;
  }

  console.log("");
  log("📬", `Processing ${toProcess.length} changed post(s)...`);
  console.log("");

  let processed = 0;
  for (const slug of toProcess) {
    const ok = await processPost(slug, hashes);
    if (ok) processed++;
    saveHashes(hashes);
    console.log("");
  }

  sep();
  log("🎉", `Done! ${processed} post(s) processed.`);
}

main().catch(e => {
  console.error(e);
  process.exit(1);
});
